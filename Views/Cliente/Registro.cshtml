@{
    ViewData["Title"] = "Crear cuenta";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Crear cuenta - Manos de Paz</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/admin.css" />
    <link rel="stylesheet" href="/css/responsive-fixes.css" />
</head>
<body class="admin-login-body">
    <div class="admin-login-box" style="max-width:420px;">
        <img src="/images/logo.jpg" alt="Manos de Paz" />
        <h2>Crear cuenta</h2>
        <p style="color:#8d6e63;margin-bottom:20px;font-size:0.95rem;">
            Regístrate y obtén descuentos VIP en todos nuestros servicios
        </p>

        @if (ViewBag.Error != null)
        {
            <div class="admin-login-error">@ViewBag.Error</div>
        }

        <form asp-action="Registro" method="post" class="admin-form" style="padding:0;box-shadow:none;text-align:left;">
            @Html.AntiForgeryToken()

            <div class="admin-form-group">
                <label for="dni">DNI</label>
                <input type="text" id="dni" name="dni" maxlength="8" pattern="\d{8}"
                       placeholder="8 dígitos numéricos" required
                       oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
                <small class="campo-error" id="error-dni" style="color:red;display:none;">El DNI debe tener exactamente 8 números.</small>
            </div>

            <div class="registro-grid">
                <div class="admin-form-group">
                    <label for="nombre">Nombre</label>
                    <input type="text
                id="nombre" name="nombre" required
                           pattern="[A-Za-záéíóúÁÉÍÓÚñÑ ]{2,50}"
                           placeholder="Solo letras" />
                    <small class="campo-error" id="error-nombre" style="color:red;display:none;">Solo se permiten letras (mín. 2 caracteres).</small>
                </div>
                <div class="admin-form-group">
                    <label for="apellido">Apellido</label>
                    <input type="text" id="apellido" name="apellido" required
                           pattern="[A-Za-záéíóúÁÉÍÓÚñÑ ]{2,50}"
                           placeholder="Solo letras" />
                    <small class="campo-error" id="error-apellido" style="color:red;display:none;">Solo se permiten letras (mín. 2 caracteres).</small>
                </div>
            </div>

            <div class="admin-form-group">
                <label for="correo">Correo electrónico</label>
                <input type="email" id="correo" name="correo" required
                       placeholder="ejemplo@@correo.com" />
                <small class="campo-error" id="error-correo" style="color:red;display:none;">Ingresa un correo válido (ejemplo@correo.com).</small>
            </div>

            <div class="admin-form-group">
                <label for="password">Contraseña</label>
                <input type="password" id="password" name="password" minlength="6" required />
                <small style="color:#8d6e63;">Mínimo 6 caracteres</small>
            </div>

            <div style="background:#fff8f0;border:1px solid #f0dcc8;border-radius:8px;padding:12px;margin-bottom:16px;font-size:0.88rem;color:#6d4c41;">
                🎁 Al registrarte obtienes automáticamente el plan <strong>VIP</strong> con <strong>15% de descuento</strong> en todas tus citas.
            </div>

            <button type="submit" class="admin-btn admin-btn-primary" style="width:100%;margin-bottom:12px;">
                Crear cuenta
            </button>
        </form>

        <p style="font-size:0.9rem;color:#6d4c41;">
            ¿Ya tienes cuenta?
            <a asp-controller="Cliente" asp-action="Login" style="color:#a65131;font-weight:600;">
                Inicia sesión
            </a>
        </p>

        <p style="margin-top:10px;">
            <a asp-controller="Home" asp-action="Bienvenida" style="font-size:0.85rem;color:#999;">
                ← Volver a Bienvenida
            </a>
        </p>
    </div>
<script>
    const form = document.querySelector('form');

    function soloLetras(valor) {
        return /^[A-Za-záéíóúÁÉÍÓÚñÑ\s]{2,50}$/.test(valor.trim());
    }
    function esCorreoValido(valor) {
        var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]{2,}$/;
        return re.test(valor.trim());
    }

    function validarCampo(inputId, errorId, fn) {
        const input = document.getElementById(inputId);
        const error = document.getElementById(errorId);
        input.addEventListener('blur', function() {
            if (!fn(input.value)) {
                error.style.display = 'block';
                input.style.borderColor = 'red';
            } else {
                error.style.display = 'none';
                input.style.borderColor = '';
            }
        });
        input.addEventListener('input', function() {
            if (fn(input.value)) {
                error.style.display = 'none';
                input.style.borderColor = '';
            }
        });
    }

    validarCampo('nombre',   'error-nombre',   soloLetras);
    validarCampo('apellido', 'error-apellido', soloLetras);
    validarCampo('correo',   'error-correo',   esCorreoValido);
    validarCampo('dni',      'error-dni',      function(v) { return /^\d{8}$/.test(v.trim()); });

    form.addEventListener('submit', function(e) {
        const dni      = document.getElementById('dni').value.trim();
        const nombre   = document.getElementById('nombre').value.trim();
        const apellido = document.getElementById('apellido').value.trim();
        const correo   = document.getElementById('correo').value.trim();
        let valido = true;

        if (!/^\d{8}$/.test(dni)) {
            document.getElementById('error-dni').style.display = 'block';
            document.getElementById('dni').style.borderColor = 'red';
            valido = false;
        }
        if (!soloLetras(nombre)) {
            document.getElementById('error-nombre').style.display = 'block';
            document.getElementById('nombre').style.borderColor = 'red';
            valido = false;
        }
        if (!soloLetras(apellido)) {
            document.getElementById('error-apellido').style.display = 'block';
            document.getElementById('apellido').style.borderColor = 'red';
            valido = false;
        }
        if (!esCorreoValido(correo)) {
            document.getElementById('error-correo').style.display = 'block';
            document.getElementById('correo').style.borderColor = 'red';
            valido = false;
        }
        if (!valido) e.preventDefault();
    });
</script>
</body>
</html>