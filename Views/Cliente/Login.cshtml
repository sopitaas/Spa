@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión - Manos de Paz</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/admin.css" />
    <link rel="stylesheet" href="/css/responsive-fixes.css" />
</head>
<body class="admin-login-body">
    <div class="admin-login-box">
        <img src="/images/logo.jpg" alt="Manos de Paz" />
        <h2>Iniciar sesión</h2>
        <p style="color:#8d6e63;margin-bottom:20px;font-size:0.95rem;">
            Accede para obtener descuentos VIP exclusivos
        </p>

        @if (ViewBag.Error != null)
        {
            <div class="admin-login-error">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post" class="admin-form" style="padding:0;box-shadow:none;text-align:left;">
            @Html.AntiForgeryToken()

            <div class="admin-form-group">
                <label for="correo">Correo electrónico</label>
                <input type="email" id="correo" name="correo" required />
            </div>

            <div class="admin-form-group">
                <label for="password">Contraseña</label>
                <input type="password" id="password" name="password" required />
            </div>

            <button type="submit" class="admin-btn admin-btn-primary" style="width:100%;margin-bottom:12px;">
                Ingresar
            </button>
        </form>

        <p style="font-size:0.9rem;color:#6d4c41;">
            ¿No tienes cuenta?
            <a asp-controller="Cliente" asp-action="Registro" style="color:#a65131;font-weight:600;">
                Regístrate aquí
            </a>
        </p>

        <p style="margin-top:10px;">
            <a asp-controller="Home" asp-action="Bienvenida" style="font-size:0.85rem;color:#999;">
                ← Volver a Bienvenida
            </a>
        </p>
    </div>
</body>
</html>
