@model List<Spa.Models.Promocion>

@{
    ViewData["Title"] = "Promociones";
}

<section class="promo">

    <h2 class="titulo">PROMOCIONES</h2>

    <div class="promociones-container">

        @if (Model != null && Model.Any())
        {
            @foreach (var promo in Model)
            {
                <div class="promocion-card">

                    <div class="promocion-header">
                        @promo.Nombre
                    </div>

                    <div class="promocion-content">

                        <img src="~/images/@promo.Imagen"
                             alt="@promo.Nombre"
                             class="promocion-image" />

                        @if (!string.IsNullOrWhiteSpace(promo.Descripcion))
                        {
                            <div class="promocion-incluye">
                                Descripción
                            </div>

                            <p class="promocion-descripcion">
                                @promo.Descripcion
                            </p>
                        }

                        <div class="promocion-precio">
                            S/ @promo.Precio
                        </div>

                        <a asp-controller="Cita"
                           asp-action="Index"
                           class="promocion-button">
                            ¡QUIERO ESTA PROMOCIÓN!
                        </a>

                    </div>

                </div>
            }
        }
        else
        {
            <div style="grid-column:1/-1;text-align:center;padding:60px;">
                <h3>No hay promociones disponibles.</h3>
            </div>
        }

    </div>

</section>