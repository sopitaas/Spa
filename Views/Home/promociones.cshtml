<!DOCTYPE html>
<html lang="es">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="stylesheet" href="/css/style.css" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
        <title>Promociones - Manos de Paz</title>
    </head>

<body>

    <header>
        <div class="logo">
            <img src="/images/logo.jpg" alt="Manos de Paz">
        </div>
        <nav>
            <a asp-controller="Home" asp-action="Index">Inicio</a>
            <a asp-controller="Nosotros" asp-action="Index">Nosotros</a>
            <a asp-controller="Servicios" asp-action="Index">Servicios</a>
            <a asp-controller="Promociones" asp-action="Index" class="activo">Promociones</a>
            <a asp-controller="Cita" asp-action="Index" class="boton">Agenda tu cita</a>
        </nav>
    </header>
    <main>
        <section class="promo">
            <h2 class="titulo">PROMOCIONES</h2>
            <div class="promociones-container">
                <!-- Cumpleaños Manos de Paz -->
                <div class="promocion-card">
                    <div class="promocion-header">
                        ¡CELEBRA DIFERENTE, CELEBRA EN MANOS DE PAZ!
                    </div>
                    <div class="promocion-content">
                        <img src="/images/promo1.png" alt="Cumpleaños Manos de Paz" class="promocion-image">

                        <h3 class="promocion-title">Cumpleaños Manos de Paz</h3>

                        <div class="promocion-incluye">Incluye:</div>
                        <ul class="promocion-lista">
                            <li>Cámara seca o vapor (30 min)</li>
                            <li>Tina de hidromasajes (30 min)</li>
                            <li>Exfoliante corporal o cultura corporal</li>
                            <li>Masaje descontracturante o relajante (30 min)</li>
                            <li>Brownie de chocolate</li>
                            <li>Copa de vino</li>
                            <li>Tarjeta de cumpleaños personalizada</li>
                        </ul>

                        <div class="promocion-precio">S/ 260 por persona</div>
                        <a asp-controller="Cita" asp-action="Index" asp-route-servicio="promo-cumple" class="promocion-button">¡QUIERO ESTA PROMOCIÓN!</a>
                    </div>
                </div>

                <!-- Ritual Clásico Full Relax -->
                <div class="promocion-card ritual-card">
                    <div class="ritual-background"></div>
                    <div class="ritual-header">
                        EL EQUILIBRIO PERFECTO ENTRE CUERPO, MENTE Y ALMA
                    </div>
                    <div class="promocion-content ritual-content">
                        <img src="/images/promo2.png" alt="Ritual clásico full relax" class="promocion-image">

                        <h3 class="promocion-title">Ritual clásico full relax</h3>

                        <div class="promocion-incluye">Incluye:</div>
                        <ul class="promocion-lista">
                            <li>Masaje relajante + descontracturante (60 min)</li>
                            <li>Jacuzzi con hidromasajes (con sal marina o burbujas)</li>
                            <li>Sauna privado con luz infrarroja (30 min)</li>
                            <li>Cortesía: copa de vino, agua y bocaditos</li>
                            <li>En celebraciones especiales: porción de pastel</li>
                        </ul>
                        <div class="promocion-precio">S/ 320 por persona</div>

                        <a asp-controller="Cita" asp-action="Index" asp-route-servicio="promo-ritual-relax" class="promocion-button">¡QUIERO ESTA PROMOCIÓN!</a>
                    </div>
                </div>
            </div>

        </section>

    </main>
    <footer class="footer">
        <div class="contenedor-footer">
            <div class="footer-col info-empresa">
                <div class="sublogo">
                    <img src="/images/lfond.png" alt="Logo" />
                </div>
                <h3>
                    Somos una empresa inclusiva de masajistas profesionales orientados a
                    brindar un excelente servicio de masajes terapéuticos.
                </h3>
                <p><strong>Horario de atención:</strong></p>
                <p>Lun. a sáb. de 7:00 am a 21:00 pm</p>
                <p>Dom. y feriados: 9:00 am a 19:00 pm</p>

                <div class="redes-sociales">
                    <a href="https://www.facebook.com/" target="_blank"><i class="fab fa-facebook-f"></i></a>
                    <a href="https://www.instagram.com/" target="_blank"><i class="fab fa-instagram"></i></a>
                </div>
            </div>

            <div class="footer-col contacto-mapa">
                <p>
                    <strong>Teléfonos:</strong><br />Reservas 01 3090095 – 999 985 050 |
                    Miraflores
                </p>
                <p>
                    <strong>Dirección:</strong><br />📍Av. Angamos Oeste 840 - Miraflores
                </p>
                <p><strong>E-mail:</strong><br />m.pazspa@gmail.com</p>
                <div class="mapa">
                    <img src="/images/mapa.png" alt="Mapa ubicación" />
                </div>
            </div>

            <div class="footer-col form-contacto">
                <h3>¿Tienes una consulta? Escríbenos</h3>
                <form>
                    <input type="text" placeholder="Nombre" required />
                    <input type="email" placeholder="Correo" required />
                    <textarea placeholder="Escribe tu mensaje..." required></textarea>
                    <button type="submit">Enviar</button>
                </form>
            </div>
        </div>
    </footer>
    <script src="/js/script.js"></script>
</body>

</html>