@model Spa.Models.Promocion

@{
    ViewData["Title"] = "Nueva Promoción";
    Layout = "_AdminLayout";
}

<form asp-action="CrearPromocion" method="post" class="admin-form">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="admin-validation"></div>

    <div class="admin-form-group">
        <label asp-for="Nombre">Nombre</label>
        <input asp-for="Nombre" type="text" />
        <span asp-validation-for="Nombre" class="admin-validation"></span>
    </div>

    <div class="admin-form-group">
        <label asp-for="Descripcion">Descripción</label>
        <textarea asp-for="Descripcion" rows="3"></textarea>
        <span asp-validation-for="Descripcion" class="admin-validation"></span>
    </div>

    <div class="admin-form-group">
        <label asp-for="Precio">Precio (S/)</label>
        <input asp-for="Precio" type="number" step="0.01" min="0" />
        <span asp-validation-for="Precio" class="admin-validation"></span>
    </div>

    <div class="admin-form-group">
        <label asp-for="Imagen">Nombre de archivo de imagen</label>
        <input asp-for="Imagen" type="text" placeholder="ejemplo: promo1.jpg" />
        <small>Debe existir en wwwroot/images/</small>
        <span asp-validation-for="Imagen" class="admin-validation"></span>
    </div>

    <div class="admin-form-group admin-form-check">
        <input asp-for="Activa" type="checkbox" />
        <label asp-for="Activa">Promoción activa</label>
    </div>

    <div class="admin-form-acciones">
        <button type="submit" class="admin-btn admin-btn-success">Guardar</button>
        <a asp-action="Promociones" class="admin-btn admin-btn-secondary">Cancelar</a>
    </div>
</form>
